  /* ─── 8. runs (agent_run) ───────────────────────── */
  runs: (function(){
    const arr = [];
    const agents = ['ag_cotizador','ag_followup','ag_bant','ag_summarizer','ag_triage','ag_pipeline','ag_saludo'];
    const states = ['completed','completed','completed','failed','completed','escalated','approved'];
    for (let i = 0; i < 54; i++) {
      const agentId = agents[i % agents.length];
      const final   = states[i % states.length];
      const started = '2026-04-' + (19 - Math.floor(i/8)) + 'T' + (8 + (i%10)) + ':' + (10 + i%50) + ':00-06:00';
      arr.push({
        id: 'run_' + (8800 + i), agentId, tenantId: 't_muito',
        startedAt: started, endedAt: started.replace(':00-06:00', ':12-06:00'),
        finalState: final,
        tokensUsed: 1200 + (i * 37) % 4000,
        costUSD: +(0.02 + (i % 9) * 0.04).toFixed(3),
        tracesCount: 5 + (i % 4)
      });
    }
    return arr;
  })(),

