  /* ─── 11. auditEvents ─────────────────────────────── */
  auditEvents: (function(){
    const events = [];
    const actions = [
      'user.login','user.logout','user.role_changed','session.created','session.revoked',
      'agent_spec.published','agent_spec.retired','agent_run.started','agent_run.completed',
      'draft.generated','draft.approved','draft.rejected','draft.expired','draft.sent','draft.escalated',
      'memory_chunk.created','memory_chunk.promoted','memory_chunk.superseded','memory_chunk.revoked',
      'connector.enabled','connector.disabled','connector.revoked',
      'policy.violation','secret.rotated','kek.access','backup.succeeded','backup.failed',
      'job.succeeded','job.skipped','break_glass.activated','break_glass.expired'
    ];
    const actors = ['u_alvaro','u_ana','u_bruno','system'];
    const severities = ['INFO','INFO','INFO','WARN','ERROR','POLICY'];
    for (let i = 0; i < 64; i++) {
      const action = actions[i % actions.length];
      const ts = new Date(Date.now() - i * 37 * 60 * 1000).toISOString();
      events.push({
        id: 'ae_' + (3000 + i), ts, tenantId: 't_muito',
        actor: actors[i % actors.length], action,
        target: action.startsWith('draft') ? 'dr_' + (String(i % 14 + 1).padStart(3, '0')) :
                action.startsWith('memory_chunk') ? 'mc_' + (200 + i) : null,
        severity: severities[i % severities.length],
        ip: '10.0.' + (i % 255) + '.' + ((i*7) % 255),
        userAgent: 'FaberLoom/1.0 (' + (i % 2 === 0 ? 'Windows' : 'macOS') + ')'
      });
    }
    return events;
  })(),

