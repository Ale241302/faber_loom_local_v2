  /* [V3.5-PATCH 2026-04-19] enrich agents with full AgentSpec fields (A4 P1) */
  (function enrichAgentsWithSpec() {
    const enrich = {
      ag_cotizador: { specVersion:'1.0.3', autonomyCeiling:'L2', escalationPolicy:'monto>500k → owner; cliente_no_recurrente → admin', kbRefs:['ENT_PROD_MAN','POL_MX_001','price_table_2026','stock_lookup'], connectorBindings:['co_postmark','co_gdrive'], events:['rfq_received','followup_due','stock_alert'], stateMachine:'default_v1', learningConsolidation:'manual_only', triggerKind:'word', tier:'demo-critical', specSupersedes:'1.0.2', createdAt:'2026-01-15', createdBy:'u_alvaro' },
      ag_followup:  { specVersion:'0.2.0', autonomyCeiling:'L1', escalationPolicy:'sin respuesta 7d → notify owner',                kbRefs:['POL_MX_001'],                                                  connectorBindings:['co_postmark'],            events:['quote_unanswered_7d'],          stateMachine:'default_v1', learningConsolidation:'manual_only', triggerKind:'event', tier:'experimental', specSupersedes:null, createdAt:'2026-03-15', createdBy:'u_alvaro' },
      ag_bant:      { specVersion:'1.2.1', autonomyCeiling:'L2', escalationPolicy:'authority unclear → ask user',                    kbRefs:['ENT_GOB_PROCESOS','crm_schema'],                               connectorBindings:['co_postmark'],            events:['lead_inbound'],                  stateMachine:'default_v1', learningConsolidation:'auto_with_review', triggerKind:'word', tier:'hot', specSupersedes:'1.2.0', createdAt:'2026-02-10', createdBy:'u_ana' },
      ag_summarizer:{ specVersion:'2.1.0', autonomyCeiling:'L3', escalationPolicy:'doc>50pp → ask owner',                            kbRefs:[],                                                              connectorBindings:[],                          events:['daily_cron'],                    stateMachine:'simple', learningConsolidation:'auto_with_review', triggerKind:'schedule', tier:'internal', specSupersedes:'2.0.5', createdAt:'2025-11-01', createdBy:'u_alvaro' },
      ag_triage:    { specVersion:'2.0.0', autonomyCeiling:'L4', escalationPolicy:'P0/P1 ticket → owner; tier1 cliente → admin',     kbRefs:['triage_playbook','sales_log'],                                  connectorBindings:['co_postmark'],            events:['ticket_inbound'],               stateMachine:'default_v1', learningConsolidation:'auto_with_review', triggerKind:'event', tier:'hot', specSupersedes:'1.5.4', createdAt:'2025-10-01', createdBy:'u_alvaro' },
      ag_pipeline:  { specVersion:'0.5.0', autonomyCeiling:'L2', escalationPolicy:'oportunidad>200k → admin',                        kbRefs:['crm_schema','price_table_2026'],                               connectorBindings:[],                          events:['daily_cron','deal_stage_change'], stateMachine:'default_v1', learningConsolidation:'manual_only', triggerKind:'word', tier:'cold', specSupersedes:null, createdAt:'2026-04-01', createdBy:'u_ana' },
      ag_saludo:    { specVersion:'1.0.0', autonomyCeiling:'L3', escalationPolicy:'first_contact → log only',                        kbRefs:[],                                                              connectorBindings:['co_postmark'],            events:['new_customer_signup'],          stateMachine:'simple', learningConsolidation:'manual_only', triggerKind:'event', tier:'cold', specSupersedes:null, createdAt:'2026-02-20', createdBy:'u_ana' }
    };
    (MOCK.agents || []).forEach(a => {
      const e = enrich[a.id]; if (!e) return;
      Object.keys(e).forEach(k => { if (a[k] === undefined) a[k] = e[k]; });
      if (!a.lifecycleStatus) a.lifecycleStatus = a.state === 'shadow' ? 'shadow' : a.state === 'idle' ? 'paused' : 'active';
    });
  })();

  FL.mock = MOCK;
