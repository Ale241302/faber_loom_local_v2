{
  "name": "faberloom-desktop",
  "version": "0.1.0",
  "description": "FaberLoom Foundation Beta desktop client (M18-M20)",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "lint": "echo 'No linter configured'",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron": "^31.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0",
    "semver": "^7.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "ai.faberloom.desktop",
    "productName": "FaberLoom",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "generic",
      "url": "${env.UPDATE_FEED_BASE_URL}"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
